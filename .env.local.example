# ============================================================
# MR + AI 研学馆 环境变量配置
# 复制本文件为 .env.local 并填写真实值
# ============================================================

# ── Supabase（必填）────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── 豆包 / Volcengine API（生成动画需要）──────────────────
DOUBAO_API_KEY=your-volcengine-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── 豆包模型 ID（按需覆盖默认值）──────────────────────────
# 视觉理解
DOUBAO_VISION_MODEL=doubao-1.5-vision-pro-250328
# 对话/故事生成
DOUBAO_CHAT_MODEL=doubao-1.5-pro-32k-250515
# 图片生成
DOUBAO_IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
# 视频生成
DOUBAO_VIDEO_MODEL=doubao-seedance-2-0

# ── 站点 URL（用于 API 回调）──────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.digit3ds.com

# ── 风格系统 ──────────────────────────────────────────────
DEFAULT_STYLE=pixar
