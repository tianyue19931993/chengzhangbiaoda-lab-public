# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 豆包 Cookie (JSON 格式)
DOUBAO_COOKIES=

# 即梦 Cookie (JSON 格式)
JIMENG_COOKIES=

# 即梦视频生成配置
JIMENG_VIDEO_MODEL=seedance-2.0
JIMENG_VIDEO_RESOLUTION=720p
JIMENG_VIDEO_DURATION=10

# 风格系统默认配置
DEFAULT_STYLE=pixar
DEFAULT_STYLE_PROMPT=Pixar animation style, 3D animated movie, cinematic lighting, cute character, high quality rendering, Disney Pixar style

# 文件清理配置
FILE_RETENTION_DAYS=7

# Playwright 配置
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=300000
