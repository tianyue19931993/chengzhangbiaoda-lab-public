# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ===== 豆包 AI (Volcengine) =====
# 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型 ID（可选，使用默认值可留空）
# DOUBAO_VISION_MODEL=doubao-1.5-vision-pro-250328
# DOUBAO_CHAT_MODEL=doubao-1.5-pro-32k-250515
# DOUBAO_IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
# DOUBAO_VIDEO_MODEL=doubao-seedance-2-0

# ===== 应用配置 =====
DEFAULT_STYLE=pixar
DEFAULT_STYLE_PROMPT=Pixar 3D 儿童动画风格，色彩明亮、角色可爱、光影柔和
FILE_RETENTION_DAYS=7

# ===== 日志 =====
NODE_ENV=development
